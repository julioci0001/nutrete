# ══════════════════════════════════════════════════════════════
# nutrEte.com.ar — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nutrete.com.ar
NEXT_PUBLIC_APP_NAME=nutrEte
NEXT_PUBLIC_APP_LOCALE=es

# ── SUPABASE ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_PROVIDER=anthropic           # anthropic | openai

# ── GEO ────────────────────────────────────────────────────────
# Vercel Edge provides geolocation natively — no extra key needed.
# Optional: ipinfo.io fallback for local dev
IPINFO_TOKEN=your_ipinfo_token

# ── TERRALEADS ─────────────────────────────────────────────────
TERRALEADS_FLOW_KEY=your_flow_key
TERRALEADS_API_URL=https://terraLeads.com/api

# ── ANALYTICS ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# ── ADMIN ──────────────────────────────────────────────────────
ADMIN_SECRET=change_this_to_a_very_long_random_secret
NEXTAUTH_SECRET=change_this_to_another_very_long_secret
NEXTAUTH_URL=https://nutrete.com.ar

# ── REDIS (optional) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CONTENT ────────────────────────────────────────────────────
CONTENT_AUTO_GENERATE=true      # Auto-generate content when a product is added
CONTENT_LANGUAGE=es             # Default generation language
